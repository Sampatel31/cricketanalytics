# ============================================================
# Sovereign Cricket Analytics - Environment Variables Template
# Copy to .env and fill in the values before running.
# ============================================================

# ----------------------------
# General
# ----------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_JSON=false
FEATURE_DIMENSIONS=64
BATCH_SIZE=256
UMAP_N_COMPONENTS=2
HDBSCAN_MIN_CLUSTER_SIZE=10

# ----------------------------
# PostgreSQL
# ----------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cricketanalytics
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_POOL_TIMEOUT=30
DB_ECHO_SQL=false

# ----------------------------
# Redis
# ----------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_POOL_MIN=5
REDIS_POOL_MAX=20
REDIS_AUCTION_TTL=14400
REDIS_SCORE_CACHE_TTL=3600

# ----------------------------
# API
# ----------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_DEBUG=false
API_SECRET_KEY=change-me-in-production
API_ALLOWED_ORIGINS=["http://localhost:3000"]
